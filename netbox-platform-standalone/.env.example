# NetBox Platform Standalone — copy to .env (never commit .env)

COMPOSE_PROJECT=netbox-platform

NETBOX_HOST_PORT=18888
NETBOX_PG_HOST_PORT=55432

NETBOX_SUPERUSER_NAME=admin
NETBOX_SUPERUSER_EMAIL=admin@example.com
NETBOX_SUPERUSER_PASSWORD=change-me-netbox-admin

NETBOX_DB_PASSWORD=change-me-netbox-db
NETBOX_SECRET_KEY=change-me-use-a-long-random-secret-key-at-least-fifty-characters
NETBOX_API_TOKEN_PEPPER_1=change-me-pepper-minimum-fifty-characters-for-v2-tokens

# Plugins image
NETBOX_BRANCHING_ENABLED=0

# Diode / Orb
DIODE_GRPC_HOST_PORT=58080
DIODE_GRPC_TARGET=grpc://diode-nginx:80/diode
NETBOX_DIODE_PLUGIN_API_BASE_URL=http://netbox:8080
NETBOX_TO_DIODE_CLIENT_SECRET=
DIODE_TO_NETBOX_CLIENT_SECRET=
DIODE_CLIENT_ID=
DIODE_CLIENT_SECRET=
DIODE_NETBOX_USERNAME=diode

DIODE_TAG=latest
DIODE_REDIS_PASSWORD=change-me-diode-redis
HYDRA_SECRETS_SYSTEM=change-me-hydra-secret-min-16-chars
HYDRA_URLS_SELF_ISSUER=http://hydra:4444
OAUTH2_PUBLIC_SERVER_URL=http://hydra:4444
DIODE_AUTH_TOKEN_URL=http://diode-auth:8080/token
DIODE_TO_NETBOX_CLIENT_ID=diode-to-netbox

# Orb host-network overlay: set in platform/orb/agent.yaml when using docker-compose.orb-host.yml
#   grpc://127.0.0.1:58080/diode
