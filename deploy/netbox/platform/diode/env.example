# Diode stack environment (lab defaults — not for production)
#
# Copy values into deploy/netbox/.env alongside F7 NetBox settings.
# After first `platform-lab-start.sh`, create Orb credentials in NetBox UI:
#   Diode → Client Credentials

# Reconciler MUST reach NetBox via Docker DNS (not 127.0.0.1)
NETBOX_DIODE_PLUGIN_API_BASE_URL=http://netbox:8080
NETBOX_DIODE_PLUGIN_SKIP_TLS_VERIFY=true

# Host port for Diode gRPC ingress (nginx)
GARD_DIODE_GRPC_HOST_PORT=58080
DIODE_GRPC_TARGET=grpc://diode-nginx:80/diode

# Diode OAuth (populate after bootstrap — see platform/diode/README.md)
NETBOX_TO_DIODE_CLIENT_SECRET=
DIODE_TO_NETBOX_CLIENT_SECRET=
DIODE_CLIENT_ID=
DIODE_CLIENT_SECRET=

DIODE_TAG=latest
DIODE_REDIS_PASSWORD=diode-redis-dev-only-change-me
HYDRA_SECRETS_SYSTEM=change-me-hydra-dev-secret-min-16-chars
HYDRA_URLS_SELF_ISSUER=http://hydra:4444
OAUTH2_PUBLIC_SERVER_URL=http://hydra:4444
DIODE_AUTH_TOKEN_URL=http://diode-auth:8080/token
DIODE_TO_NETBOX_CLIENT_ID=diode-to-netbox
