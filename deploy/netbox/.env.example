# GARD F7 + F13 NetBox dev stack — copy to deploy/netbox/.env
#
# F7 only:
#   docker compose -p gard-f7-netbox -f deploy/netbox/docker-compose.yml --env-file deploy/netbox/.env up -d
#
# F13 platform lab (NetBox + Diode + Orb):
#   ./deploy/scripts/platform-lab-start.sh

# --- F7 NetBox core ---
GARD_NETBOX_HOST_PORT=18888
GARD_NETBOX_PG_HOST_PORT=55432

NETBOX_SUPERUSER_NAME=admin
NETBOX_SUPERUSER_EMAIL=admin@example.com
NETBOX_SUPERUSER_PASSWORD=gard-f7-netbox-dev

NETBOX_DB_PASSWORD=netbox-dev-password
NETBOX_SECRET_KEY=gard-f7-netbox-not-for-production-change-me-use-a-longer-secret-key
NETBOX_API_TOKEN_PEPPER_1=gard-f7-netbox-dev-pepper-not-for-production-minimum-fifty-chars

# --- F13 platform lab (optional) ---
GARD_NETBOX_PLATFORM=1
GARD_NETBOX_BRANCHING_ENABLED=0

# Diode / Orb (populate secrets locally — never commit real values)
GARD_DIODE_GRPC_HOST_PORT=58080
DIODE_GRPC_TARGET=grpc://diode-nginx:80/diode
NETBOX_DIODE_PLUGIN_API_BASE_URL=http://netbox:8080
NETBOX_TO_DIODE_CLIENT_SECRET=
DIODE_TO_NETBOX_CLIENT_SECRET=
DIODE_CLIENT_ID=
DIODE_CLIENT_SECRET=
DIODE_NETBOX_USERNAME=diode

DIODE_TAG=latest
DIODE_REDIS_PASSWORD=diode-redis-dev-only-change-me
HYDRA_SECRETS_SYSTEM=change-me-hydra-dev-secret-min-16-chars
# Hydra public URL (Docker DNS — see netboxlabs/diode sample.env)
HYDRA_URLS_SELF_ISSUER=http://hydra:4444
OAUTH2_PUBLIC_SERVER_URL=http://hydra:4444
DIODE_AUTH_TOKEN_URL=http://diode-auth:8080/token
DIODE_TO_NETBOX_CLIENT_ID=diode-to-netbox
